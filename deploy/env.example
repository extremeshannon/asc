# Copy to platform-py/.env or export before `docker compose` if you override paths.
#
# Host path to this ASC repository (absolute path recommended on Linux/VPS).
# Default in platform-py compose is ../../ASC relative to platform-py/.
#
# ASC_REPO_PATH=/home/you/projects/ASC
#
# Public marketing site (this repo): docker compose up -d  →  http://localhost:8006/
# MalfunctionDZ API: ../platform/platform-py  →  http://localhost:8000/
